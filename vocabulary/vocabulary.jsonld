        "@id": "deribit:currency_with_apr"
      }
    },
    {
      "@id": "deribit:currency_with_apr_min_confirmations",
      "@type": "rdf:Property",
      "rdfs:label": "Min Confirmations",
      "rdfs:comment": "Minimum number of block chain confirmations before deposit is accepted.",
      "rdfs:domain": {
        "@id": "deribit:currency_with_apr"
      }
    },
    {
      "@id": "deribit:currency_with_apr_coin_type",
      "@type": "rdf:Property",
      "rdfs:label": "Coin Type",
      "rdfs:comment": "The type of the currency.",
      "rdfs:domain": {
        "@id": "deribit:currency_with_apr"
      }
    },
    {
      "@id": "deribit:currency_with_apr_in_cross_collateral_pool",
      "@type": "rdf:Property",
      "rdfs:label": "In Cross Collateral Pool",
      "rdfs:comment": "`true` if the currency is part of the cross collateral pool",
