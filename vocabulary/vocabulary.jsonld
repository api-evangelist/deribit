      "rdfs:label": "Min Price",
      "rdfs:comment": "The minimum price for the future. Any sell orders you submit lower than this price will be clamped to this minimum."
    },
    {
      "@id": "deribit:max_price",
      "@type": "rdfs:Class",
      "rdfs:label": "Max Price",
      "rdfs:comment": "The maximum price for the future. Any buy orders you submit higher than this price, will be clamped to this maximum."
    },
    {
      "@id": "deribit:mark_price",
      "@type": "rdfs:Class",
