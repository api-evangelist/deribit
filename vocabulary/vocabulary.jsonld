      "@id": "deribit:user_trade_quote_set_id",
      "@type": "rdf:Property",
      "rdfs:label": "Quote Set Id",
      "rdfs:comment": "QuoteSet of the user order (optional, present only for orders placed with `private/mass_quote`)",
      "rdfs:domain": {
