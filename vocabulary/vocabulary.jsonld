      "rdfs:comment": "The number of contracts to be traded."
    },
    {
      "@id": "deribit:average_price",
      "@type": "rdfs:Class",
      "rdfs:label": "Average Price",
      "rdfs:comment": "Average fill price of the order"
    },
    {
      "@id": "deribit:commission",
      "@type": "rdfs:Class",
      "rdfs:label": "Commission",
      "rdfs:comment": "Commission paid so far (in base currency)"
    },
    {
      "@id": "deribit:advanced",
      "@type": "rdfs:Class",
      "rdfs:label": "Advanced",
      "rdfs:comment": "advanced type: `\"usd\"` or `\"implv\"` (Only for options; field is omitted if not applicable).\n"
