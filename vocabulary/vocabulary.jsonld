      }
    },
    {
      "@id": "deribit:block_trade_trades",
      "@type": "rdf:Property",
      "rdfs:label": "Trades",
      "rdfs:comment": "trades property of block_trade",
      "rdfs:domain": {
        "@id": "deribit:block_trade"
      }
    },
    {
      "@id": "deribit:block_trade_app_name",
      "@type": "rdf:Property",
      "rdfs:label": "App Name",
      "rdfs:comment": "The name of the application that executed the block trade on behalf of the user (optional).",
