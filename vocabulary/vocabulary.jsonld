      "rdfs:label": "Secure",
      "rdfs:comment": "secure property of withdrawal_policy_limit_buckets",
      "rdfs:domain": {
        "@id": "deribit:withdrawal_policy_limit_buckets"
      }
    },
    {
      "@id": "deribit:withdrawal_policy_amount",
      "@type": "rdfs:Class",
      "rdfs:label": "Withdrawal Policy Amount",
      "rdfs:comment": "A positive float as limit"
    },
    {
      "@id": "deribit:oco_ref",
      "@type": "rdfs:Class",
      "rdfs:label": "Oco Ref",
      "rdfs:comment": "Unique reference that identifies a one_cancels_others (OCO) pair."
