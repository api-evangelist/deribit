    {
      "@id": "deribit:pending_block_trade_role",
      "@type": "rdf:Property",
      "rdfs:label": "Role",
      "rdfs:comment": "role property of pending_block_trade",
      "rdfs:domain": {
        "@id": "deribit:pending_block_trade"
      }
    },
    {
      "@id": "deribit:pending_block_trade_user_id",
      "@type": "rdf:Property",
      "rdfs:label": "User Id",
      "rdfs:comment": "user_id property of pending_block_trade",
      "rdfs:domain": {
        "@id": "deribit:pending_block_trade"
      }
