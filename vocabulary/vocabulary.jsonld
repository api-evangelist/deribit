      }
    },
    {
      "@id": "deribit:access_log_ip",
      "@type": "rdf:Property",
      "rdfs:label": "Ip",
      "rdfs:comment": "IP address of source that generated action",
      "rdfs:domain": {
        "@id": "deribit:access_log"
      }
    },
    {
      "@id": "deribit:access_log_timestamp",
      "@type": "rdf:Property",
      "rdfs:label": "Timestamp",
      "rdfs:comment": "timestamp property of access_log",
      "rdfs:domain": {
