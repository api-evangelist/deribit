      "@type": "rdf:Property",
      "rdfs:label": "Block Trade Id",
      "rdfs:comment": "block_trade_id property of public_trade",
      "rdfs:domain": {
        "@id": "deribit:public_trade"
      }
    },
    {
      "@id": "deribit:public_trade_block_trade_leg_count",
      "@type": "rdf:Property",
