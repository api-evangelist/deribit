      "@type": "rdf:Property",
      "rdfs:label": "Trades",
      "rdfs:comment": "trades property of position_move",
      "rdfs:domain": {
        "@id": "deribit:position_move"
      }
    },
    {
      "@id": "deribit:transaction_log",
      "@type": "rdfs:Class",
      "rdfs:label": "Transaction Log",
      "rdfs:comment": "Deribit transaction_log object"
    },
    {
      "@id": "deribit:transaction_log_id",
      "@type": "rdf:Property",
      "rdfs:label": "Id",
      "rdfs:comment": "id property of transaction_log",
      "rdfs:domain": {
        "@id": "deribit:transaction_log"
      }
    },
    {
      "@id": "deribit:transaction_log_currency",
      "@type": "rdf:Property",
      "rdfs:label": "Currency",
      "rdfs:comment": "currency property of transaction_log",
      "rdfs:domain": {
        "@id": "deribit:transaction_log"
      }
    },
    {
      "@id": "deribit:transaction_log_timestamp",
      "@type": "rdf:Property",
      "rdfs:label": "Timestamp",
      "rdfs:comment": "timestamp property of transaction_log",
      "rdfs:domain": {
        "@id": "deribit:transaction_log"
      }
    },
    {
      "@id": "deribit:transaction_log_user_id",
      "@type": "rdf:Property",
      "rdfs:label": "User Id",
      "rdfs:comment": "user_id property of transaction_log",
      "rdfs:domain": {
        "@id": "deribit:transaction_log"
      }
    },
    {
      "@id": "deribit:transaction_log_username",
      "@type": "rdf:Property",
      "rdfs:label": "Username",
      "rdfs:comment": "username property of transaction_log",
      "rdfs:domain": {
        "@id": "deribit:transaction_log"
      }
    },
    {
      "@id": "deribit:transaction_log_commission",
      "@type": "rdf:Property",
      "rdfs:label": "Commission",
      "rdfs:comment": "commission property of transaction_log",
      "rdfs:domain": {
        "@id": "deribit:transaction_log"
      }
    },
    {
      "@id": "deribit:transaction_log_cashflow",
      "@type": "rdf:Property",
      "rdfs:label": "Cashflow",
      "rdfs:comment": "For futures and perpetual contracts: Realized session PNL (since last settlement). For options: the amount paid or received for the options traded.",
      "rdfs:domain": {
        "@id": "deribit:transaction_log"
      }
    },
    {
      "@id": "deribit:transaction_log_balance",
      "@type": "rdf:Property",
      "rdfs:label": "Balance",
      "rdfs:comment": "Cash balance after the transaction",
      "rdfs:domain": {
        "@id": "deribit:transaction_log"
      }
    },
    {
      "@id": "deribit:transaction_log_change",
      "@type": "rdf:Property",
      "rdfs:label": "Change",
      "rdfs:comment": "Change in cash balance. For trades: fees and options premium paid/received. For settlement: Futures session PNL and perpetual session funding.",
      "rdfs:domain": {
        "@id": "deribit:transaction_log"
      }
    },
    {
      "@id": "deribit:transaction_log_user_seq",
      "@type": "rdf:Property",
      "rdfs:label": "User Seq",
      "rdfs:comment": "Sequential identifier of user transaction",
      "rdfs:domain": {
        "@id": "deribit:transaction_log"
      }
    },
    {
      "@id": "deribit:transaction_log_type",
      "@type": "rdf:Property",
      "rdfs:label": "Type",
      "rdfs:comment": "Transaction category/type. The most common are: `trade`, `deposit`, `withdrawal`, `settlement`, `delivery`, `transfer`, `swap`, `correction`. New types can be added any time in the future",
      "rdfs:domain": {
        "@id": "deribit:transaction_log"
      }
    },
    {
      "@id": "deribit:transaction_log_info",
      "@type": "rdf:Property",
      "rdfs:label": "Info",
      "rdfs:comment": "Additional information regarding transaction. Strongly dependent on the log entry type",
      "rdfs:domain": {
        "@id": "deribit:transaction_log"
      }
    },
    {
      "@id": "deribit:transaction_log_equity",
      "@type": "rdf:Property",
      "rdfs:label": "Equity",
      "rdfs:comment": "Updated equity value after the transaction",
      "rdfs:domain": {
        "@id": "deribit:transaction_log"
      }
    },
    {
      "@id": "deribit:transaction_log_mark_price",
      "@type": "rdf:Property",
      "rdfs:label": "Mark Price",
      "rdfs:comment": "Market price during the trade",
      "rdfs:domain": {
        "@id": "deribit:transaction_log"
      }
    },
    {
      "@id": "deribit:transaction_log_settlement_price",
      "@type": "rdf:Property",
      "rdfs:label": "Settlement Price",
      "rdfs:comment": "The settlement price for the instrument during the delivery",
      "rdfs:domain": {
        "@id": "deribit:transaction_log"
      }
    },
    {
      "@id": "deribit:transaction_log_index_price",
      "@type": "rdf:Property",
      "rdfs:label": "Index Price",
      "rdfs:comment": "The index price for the instrument during the delivery",
      "rdfs:domain": {
        "@id": "deribit:transaction_log"
      }
    },
    {
      "@id": "deribit:transaction_log_instrument_name",
      "@type": "rdf:Property",
      "rdfs:label": "Instrument Name",
      "rdfs:comment": "instrument_name property of transaction_log",
      "rdfs:domain": {
        "@id": "deribit:transaction_log"
      }
    },
    {
      "@id": "deribit:transaction_log_position",
      "@type": "rdf:Property",
      "rdfs:label": "Position",
      "rdfs:comment": "Updated position size after the transaction",
      "rdfs:domain": {
        "@id": "deribit:transaction_log"
      }
    },
    {
      "@id": "deribit:transaction_log_side",
      "@type": "rdf:Property",
      "rdfs:label": "Side",
      "rdfs:comment": "One of: `short` or `long` in case of settlements, `close sell` or `close buy` in case of deliveries, `open sell`, `open buy`, `close sell`, `close buy` in case of trades",
