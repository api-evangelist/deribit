      "rdfs:domain": {
        "@id": "deribit:group_rate_and_burst"
      }
    },
    {
      "@id": "deribit:group_rate_and_burst_options",
      "@type": "rdf:Property",
      "rdfs:label": "Options",
      "rdfs:comment": "options property of group_rate_and_burst",
