      "rdfs:comment": "Indicates whether the RFQ was created as non-anonymous, meaning taker and maker aliases are visible to counterparties.",
      "rdfs:domain": {
        "@id": "deribit:block_rfq"
      }
    },
    {
      "@id": "deribit:block_rfq_taker",
      "@type": "rdf:Property",
      "rdfs:label": "Taker",
      "rdfs:comment": "Taker alias. Present only when `disclosed` is `true`.",
      "rdfs:domain": {
        "@id": "deribit:block_rfq"
      }
    },
    {
      "@id": "deribit:block_rfq_index_prices",
      "@type": "rdf:Property",
      "rdfs:label": "Index Prices",
      "rdfs:comment": "index_prices property of block_rfq",
      "rdfs:domain": {
        "@id": "deribit:block_rfq"
      }
    },
    {
      "@id": "deribit:block_rfq_included_in_taker_rating",
      "@type": "rdf:Property",
      "rdfs:label": "Included In Taker Rating",
      "rdfs:comment": "Indicates whether the RFQ is included in the taker's rating calculation. Present only for closed RFQs created by the requesting taker.",
      "rdfs:domain": {
        "@id": "deribit:block_rfq"
      }
    },
    {
      "@id": "deribit:block_rfq_trades",
      "@type": "rdf:Property",
      "rdfs:label": "Trades",
      "rdfs:comment": "trades property of block_rfq",
      "rdfs:domain": {
        "@id": "deribit:block_rfq"
      }
    },
    {
      "@id": "deribit:block_rfq_trade_trigger",
      "@type": "rdf:Property",
      "rdfs:label": "Trade Trigger",
      "rdfs:comment": "Present only if a trade trigger was placed by the taker and only visible to taker. Only for cases: `cancelled` (contains the reason for cancellation) and `untriggered` (contains the information about the trade trigger).",
      "rdfs:domain": {
        "@id": "deribit:block_rfq"
      }
    },
    {
      "@id": "deribit:block_rfq_trade_allocations",
      "@type": "rdf:Property",
      "rdfs:label": "Trade Allocations",
      "rdfs:comment": "List of allocations for Block RFQ pre-allocation. Allows to split amount between different (sub)accounts. The taker can also allocate to himself. Visible only to the taker.",
      "rdfs:domain": {
        "@id": "deribit:block_rfq"
      }
    },
