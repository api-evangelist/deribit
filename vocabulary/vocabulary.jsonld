      }
    },
    {
      "@id": "deribit:public_trade_liquidation",
      "@type": "rdf:Property",
      "rdfs:label": "Liquidation",
      "rdfs:comment": "Optional field (only for trades caused by liquidation): `\"M\"` when maker side of trade was under liquidation, `\"T\"` when taker side was under liquidation, `\"MT\"` when both sides of trade were under liquidation",
      "rdfs:domain": {
        "@id": "deribit:public_trade"
