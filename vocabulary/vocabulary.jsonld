      "rdfs:comment": "block_trade_leg_count property of public_trade",
      "rdfs:domain": {
        "@id": "deribit:public_trade"
      }
    },
    {
      "@id": "deribit:public_trade_combo_id",
      "@type": "rdf:Property",
      "rdfs:label": "Combo Id",
      "rdfs:comment": "Optional field containing combo instrument name if the trade is a combo trade",
      "rdfs:domain": {
        "@id": "deribit:public_trade"
      }
    },
    {
      "@id": "deribit:public_trade_combo_trade_id",
      "@type": "rdf:Property",
      "rdfs:label": "Combo Trade Id",
      "rdfs:comment": "Optional field containing combo trade identifier if the trade is a combo trade",
      "rdfs:domain": {
        "@id": "deribit:public_trade"
      }
    },
    {
      "@id": "deribit:public_trade_block_rfq_id",
      "@type": "rdf:Property",
      "rdfs:label": "Block Rfq Id",
      "rdfs:comment": "ID of the Block RFQ - when trade was part of the Block RFQ",
      "rdfs:domain": {
        "@id": "deribit:public_trade"
      }
    },
    {
      "@id": "deribit:user_trade",
      "@type": "rdfs:Class",
      "rdfs:label": "User Trade",
      "rdfs:comment": "Deribit user_trade object"
    },
    {
      "@id": "deribit:user_trade_trade_id",
      "@type": "rdf:Property",
      "rdfs:label": "Trade Id",
      "rdfs:comment": "trade_id property of user_trade",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_trade_seq",
      "@type": "rdf:Property",
      "rdfs:label": "Trade Seq",
      "rdfs:comment": "trade_seq property of user_trade",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_instrument_name",
      "@type": "rdf:Property",
      "rdfs:label": "Instrument Name",
      "rdfs:comment": "instrument_name property of user_trade",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_timestamp",
      "@type": "rdf:Property",
      "rdfs:label": "Timestamp",
      "rdfs:comment": "timestamp property of user_trade",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_order_type",
      "@type": "rdf:Property",
      "rdfs:label": "Order Type",
      "rdfs:comment": "Order type: `\"limit`, `\"market\"`, or `\"liquidation\"`",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_advanced",
      "@type": "rdf:Property",
      "rdfs:label": "Advanced",
      "rdfs:comment": "Advanced type of user order: `\"usd\"` or `\"implv\"` (only for options; omitted if not applicable)",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_order_id",
      "@type": "rdf:Property",
      "rdfs:label": "Order Id",
      "rdfs:comment": "Id of the user order (maker or taker), i.e. subscriber's order id that took part in the trade",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_matching_id",
      "@type": "rdf:Property",
      "rdfs:label": "Matching Id",
      "rdfs:comment": "Always `null`",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_direction",
      "@type": "rdf:Property",
      "rdfs:label": "Direction",
      "rdfs:comment": "Trade direction of the taker",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_tick_direction",
      "@type": "rdf:Property",
      "rdfs:label": "Tick Direction",
      "rdfs:comment": "tick_direction property of user_trade",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_index_price",
      "@type": "rdf:Property",
      "rdfs:label": "Index Price",
      "rdfs:comment": "Index Price at the moment of trade",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_price",
      "@type": "rdf:Property",
      "rdfs:label": "Price",
      "rdfs:comment": "The price of the trade",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_amount",
      "@type": "rdf:Property",
      "rdfs:label": "Amount",
      "rdfs:comment": "Trade amount. For perpetual and inverse futures the amount is in USD units. For options and linear futures it is the underlying base currency coin.",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_contracts",
      "@type": "rdf:Property",
      "rdfs:label": "Contracts",
      "rdfs:comment": "Trade size in contract units (optional, may be absent in historical trades)",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_iv",
      "@type": "rdf:Property",
      "rdfs:label": "Iv",
      "rdfs:comment": "Option implied volatility for the price (Option only)",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_underlying_price",
      "@type": "rdf:Property",
      "rdfs:label": "Underlying Price",
      "rdfs:comment": "Underlying price for implied volatility calculations (Options only)",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_liquidation",
      "@type": "rdf:Property",
      "rdfs:label": "Liquidation",
      "rdfs:comment": "Optional field (only for trades caused by liquidation): `\"M\"` when maker side of trade was under liquidation, `\"T\"` when taker side was under liquidation, `\"MT\"` when both sides of trade were under liquidation",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_liquidity",
      "@type": "rdf:Property",
      "rdfs:label": "Liquidity",
      "rdfs:comment": "Describes what was role of users order: `\"M\"` when it was maker order, `\"T\"` when it was taker order",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_fee",
      "@type": "rdf:Property",
      "rdfs:label": "Fee",
      "rdfs:comment": "User's fee in units of the specified `fee_currency`",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_fee_currency",
      "@type": "rdf:Property",
      "rdfs:label": "Fee Currency",
      "rdfs:comment": "fee_currency property of user_trade",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_label",
      "@type": "rdf:Property",
      "rdfs:label": "Label",
      "rdfs:comment": "label property of user_trade",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_state",
      "@type": "rdf:Property",
      "rdfs:label": "State",
      "rdfs:comment": "state property of user_trade",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_block_trade_id",
      "@type": "rdf:Property",
      "rdfs:label": "Block Trade Id",
      "rdfs:comment": "block_trade_id property of user_trade",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_block_rfq_id",
      "@type": "rdf:Property",
      "rdfs:label": "Block Rfq Id",
      "rdfs:comment": "ID of the Block RFQ - when trade was part of the Block RFQ",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_block_rfq_quote_id",
      "@type": "rdf:Property",
      "rdfs:label": "Block Rfq Quote Id",
      "rdfs:comment": "ID of the Block RFQ quote - when trade was part of the Block RFQ",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_reduce_only",
      "@type": "rdf:Property",
      "rdfs:label": "Reduce Only",
      "rdfs:comment": "`true` if user order is reduce-only",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_post_only",
      "@type": "rdf:Property",
      "rdfs:label": "Post Only",
      "rdfs:comment": "`true` if user order is post-only",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_mmp",
      "@type": "rdf:Property",
      "rdfs:label": "Mmp",
      "rdfs:comment": "`true` if user order is MMP",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_risk_reducing",
      "@type": "rdf:Property",
      "rdfs:label": "Risk Reducing",
      "rdfs:comment": "`true` if user order is marked by the platform as a risk reducing order (can apply only to orders placed by PM users)",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_api",
      "@type": "rdf:Property",
      "rdfs:label": "Api",
      "rdfs:comment": "`true` if user order was created with API",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_profit_loss",
      "@type": "rdf:Property",
      "rdfs:label": "Profit Loss",
      "rdfs:comment": "profit_loss property of user_trade",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_mark_price",
      "@type": "rdf:Property",
      "rdfs:label": "Mark Price",
      "rdfs:comment": "Mark Price at the moment of trade",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_legs",
      "@type": "rdf:Property",
      "rdfs:label": "Legs",
      "rdfs:comment": "Optional field containing leg trades if trade is a combo trade (present when querying for **only** combo trades and in `combo_trades` events)",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_combo_id",
      "@type": "rdf:Property",
      "rdfs:label": "Combo Id",
      "rdfs:comment": "Optional field containing combo instrument name if the trade is a combo trade",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
    {
      "@id": "deribit:user_trade_combo_trade_id",
      "@type": "rdf:Property",
      "rdfs:label": "Combo Trade Id",
      "rdfs:comment": "Optional field containing combo trade identifier if the trade is a combo trade",
      "rdfs:domain": {
        "@id": "deribit:user_trade"
      }
    },
