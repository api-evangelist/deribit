      "@type": "rdfs:Class",
      "rdfs:label": "Currency",
      "rdfs:comment": "Currency, i.e `\"BTC\"`, `\"ETH\"`, `\"USDC\"`"
    },
    {
      "@id": "deribit:currency_with_apr",
      "@type": "rdfs:Class",
      "rdfs:label": "Currency With Apr",
      "rdfs:comment": "Deribit currency_with_apr object"
    },
    {
      "@id": "deribit:currency_with_apr_withdrawal_fee",
      "@type": "rdf:Property",
      "rdfs:label": "Withdrawal Fee",
      "rdfs:comment": "The total transaction fee paid for withdrawals",
      "rdfs:domain": {
        "@id": "deribit:currency_with_apr"
      }
    },
    {
      "@id": "deribit:currency_with_apr_withdrawal_priorities",
