      "rdfs:comment": "The account's fee balance (it can be used to pay for fees)"
    },
    {
      "@id": "deribit:did",
      "@type": "rdfs:Class",
      "rdfs:label": "Did",
      "rdfs:comment": "Distributed ID"
    },
    {
      "@id": "deribit:jurisdictions",
      "@type": "rdfs:Class",
      "rdfs:label": "Jurisdictions",
      "rdfs:comment": "Jurisdictions a VASP belongs to"
    },
    {
      "@id": "deribit:vasp_name",
      "@type": "rdfs:Class",
      "rdfs:label": "Vasp Name",
      "rdfs:comment": "VASP name"
    },
    {
      "@id": "deribit:source",
      "@type": "rdfs:Class",
      "rdfs:label": "Source",
      "rdfs:comment": "Blockchain address source"
    },
    {
      "@id": "deribit:jwt",
      "@type": "rdfs:Class",
      "rdfs:label": "Jwt",
      "rdfs:comment": "JSON web token"
    },
    {
      "@id": "deribit:external_id",
      "@type": "rdfs:Class",
      "rdfs:label": "External Id",
      "rdfs:comment": "User ID in external systems"
    },
    {
      "@id": "deribit:business_registration_number",
      "@type": "rdfs:Class",
      "rdfs:label": "Business Registration Number",
      "rdfs:comment": "Registration number of the company"
    },
    {
      "@id": "deribit:trigger_fill_condition",
      "@type": "rdfs:Class",
      "rdfs:label": "Trigger Fill Condition",
      "rdfs:comment": "<p>The fill condition of the linked order (Only for linked order types), default: `first_hit`.</p> <ul> <li>`\"first_hit\"` - any execution of the primary order will fully cancel/place all secondary orders.</li> <li>`\"complete_fill\"` - a complete execution (meaning the primary order no longer exists) will cancel/place the secondary orders.</li> <li>`\"incremental\"` - any fill of the primary order will cause proportional partial cancellation/placement of the secondary order. The amount that will be subtracted/added to the secondary order will be rounded down to the contract size.</li> </ul>"
    },
    {
      "@id": "deribit:withdrawal_policy_limit_bucket",
      "@type": "rdfs:Class",
      "rdfs:label": "Withdrawal Policy Limit Bucket",
      "rdfs:comment": "Withdrawal Policy limit bucket, i.e. `\"h24\"`"
    },
    {
      "@id": "deribit:withdrawal_policy_category",
      "@type": "rdfs:Class",
      "rdfs:label": "Withdrawal Policy Category",
      "rdfs:comment": "Withdrawal Policy category, i.e. `\"small\"`, `\"secure\"`"
    },
    {
      "@id": "deribit:withdrawal_policy_limit_buckets",
      "@type": "rdfs:Class",
      "rdfs:label": "Withdrawal Policy Limit Buckets",
      "rdfs:comment": "Withdrawal Policy limit bucket"
    },
    {
      "@id": "deribit:withdrawal_policy_limit_buckets_small",
