{
  "@context": {
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "schema": "https://schema.org/",
    "deribit": "https://api-evangelist.github.io/deribit/vocabulary/"
  },
  "@graph": [
    {
      "@id": "deribit:custody_account",
      "@type": "rdfs:Class",
      "rdfs:label": "Custody Account",
      "rdfs:comment": "Custody account"
    },
    {
      "@id": "deribit:custody_account_currency",
      "@type": "rdf:Property",
      "rdfs:label": "Currency",
      "rdfs:comment": "currency property of custody_account",
      "rdfs:domain": {
        "@id": "deribit:custody_account"
      }
    },
    {
      "@id": "deribit:custody_account_name",
      "@type": "rdf:Property",
      "rdfs:label": "Name",
      "rdfs:comment": "name property of custody_account",
      "rdfs:domain": {
        "@id": "deribit:custody_account"
      }
    },
    {
      "@id": "deribit:custody_account_balance",
      "@type": "rdf:Property",
      "rdfs:label": "Balance",
      "rdfs:comment": "Balance available on custody account",
      "rdfs:domain": {
        "@id": "deribit:custody_account"
      }
    },
    {
      "@id": "deribit:custody_account_pending_withdrawal_balance",
      "@type": "rdf:Property",
      "rdfs:label": "Pending Withdrawal Balance",
      "rdfs:comment": "Pending balance transferred from trading account to custody account",
      "rdfs:domain": {
        "@id": "deribit:custody_account"
      }
    },
    {
      "@id": "deribit:custody_account_auto_deposit",
      "@type": "rdf:Property",
      "rdfs:label": "Auto Deposit",
      "rdfs:comment": "When set to 'true' all new funds added to custody balance will be automatically transferred to trading balance",
      "rdfs:domain": {
        "@id": "deribit:custody_account"
      }
    },
    {
      "@id": "deribit:custody_account_client_id",
      "@type": "rdf:Property",
      "rdfs:label": "Client Id",
      "rdfs:comment": "API key 'client id' used to reserve/release funds in custody platform, requires scope 'custody:read_write'",
      "rdfs:domain": {
        "@id": "deribit:custody_account"
      }
    },
    {
      "@id": "deribit:custody_account_external_id",
      "@type": "rdf:Property",
      "rdfs:label": "External Id",
      "rdfs:comment": "external_id property of custody_account",
      "rdfs:domain": {
        "@id": "deribit:custody_account"
      }
    },
    {
      "@id": "deribit:custody_account_withdrawal_address",
      "@type": "rdf:Property",
      "rdfs:label": "Withdrawal Address",
      "rdfs:comment": "Address that is used for withdrawals",
      "rdfs:domain": {
        "@id": "deribit:custody_account"
      }
    },
    {
      "@id": "deribit:custody_account_withdrawal_address_change",
      "@type": "rdf:Property",
      "rdfs:label": "Withdrawal Address Change",
      "rdfs:comment": "UNIX timestamp after when new withdrawal address will be used for withdrawals",
      "rdfs:domain": {
        "@id": "deribit:custody_account"
      }
    },
    {
      "@id": "deribit:custody_account_pending_withdrawal_addres",
      "@type": "rdf:Property",
      "rdfs:label": "Pending Withdrawal Addres",
      "rdfs:comment": "New withdrawal address that will be used after 'withdrawal_address_change'",
      "rdfs:domain": {
        "@id": "deribit:custody_account"
      }
    },
    {
      "@id": "deribit:custody_account_deposit_address",
      "@type": "rdf:Property",
      "rdfs:label": "Deposit Address",
      "rdfs:comment": "Address that can be used for deposits",
      "rdfs:domain": {
        "@id": "deribit:custody_account"
      }
    },
    {
      "@id": "deribit:custody_log",
      "@type": "rdfs:Class",
      "rdfs:label": "Custody Log",
      "rdfs:comment": "Custody log"
    },
    {
      "@id": "deribit:custody_log_currency",
      "@type": "rdf:Property",
      "rdfs:label": "Currency",
      "rdfs:comment": "currency property of custody_log",
      "rdfs:domain": {
        "@id": "deribit:custody_log"
      }
    },
    {
      "@id": "deribit:custody_log_request_id",
      "@type": "rdf:Property",
      "rdfs:label": "Request Id",
      "rdfs:comment": "Request ID",
      "rdfs:domain": {
        "@id": "deribit:custody_log"
      }
    },
    {
      "@id": "deribit:custody_log_request",
      "@type": "rdf:Property",
      "rdfs:label": "Request",
      "rdfs:comment": "Request type",
      "rdfs:domain": {
        "@id": "deribit:custody_log"
      }
    },
    {
      "@id": "deribit:custody_log_success",
      "@type": "rdf:Property",
      "rdfs:label": "Success",
      "rdfs:comment": "When request was successful set to `true`",
      "rdfs:domain": {
        "@id": "deribit:custody_log"
      }
    },
    {
      "@id": "deribit:custody_log_timestamp",
      "@type": "rdf:Property",
      "rdfs:label": "Timestamp",
      "rdfs:comment": "timestamp property of custody_log",
      "rdfs:domain": {
        "@id": "deribit:custody_log"
      }
    },
    {
      "@id": "deribit:custody_log_amount",
      "@type": "rdf:Property",
      "rdfs:label": "Amount",
      "rdfs:comment": "amount property of custody_log",
      "rdfs:domain": {
        "@id": "deribit:custody_log"
      }
    },
    {
      "@id": "deribit:book_summary",
      "@type": "rdfs:Class",
      "rdfs:label": "Book Summary",
      "rdfs:comment": "Deribit book_summary object"
    },
    {
      "@id": "deribit:book_summary_instrument_name",
      "@type": "rdf:Property",
      "rdfs:label": "Instrument Name",
      "rdfs:comment": "instrument_name property of book_summary",
      "rdfs:domain": {
        "@id": "deribit:book_summary"
      }
    },
    {
      "@id": "deribit:book_summary_high",
      "@type": "rdf:Property",
      "rdfs:label": "High",
      "rdfs:comment": "Price of the 24h highest trade",
      "rdfs:domain": {
        "@id": "deribit:book_summary"
      }
    },
    {
      "@id": "deribit:book_summary_low",
      "@type": "rdf:Property",
      "rdfs:label": "Low",
      "rdfs:comment": "Price of the 24h lowest trade, `null` if there weren't any trades",
      "rdfs:domain": {
        "@id": "deribit:book_summary"
      }
    },
    {
      "@id": "deribit:book_summary_base_currency",
      "@type": "rdf:Property",
      "rdfs:label": "Base Currency",
      "rdfs:comment": "Base currency",
      "rdfs:domain": {
        "@id": "deribit:book_summary"
      }
    },
    {
      "@id": "deribit:book_summary_quote_currency",
      "@type": "rdf:Property",
      "rdfs:label": "Quote Currency",
      "rdfs:comment": "Quote currency",
      "rdfs:domain": {
        "@id": "deribit:book_summary"
      }
    },
    {
      "@id": "deribit:book_summary_volume",
      "@type": "rdf:Property",
      "rdfs:label": "Volume",
      "rdfs:comment": "The total 24h traded volume (in base currency)",
      "rdfs:domain": {
        "@id": "deribit:book_summary"
      }
    },
    {
      "@id": "deribit:book_summary_bid_price",
      "@type": "rdf:Property",
      "rdfs:label": "Bid Price",
      "rdfs:comment": "The current best bid price, `null` if there aren't any bids",
      "rdfs:domain": {
        "@id": "deribit:book_summary"
      }
    },
    {
      "@id": "deribit:book_summary_ask_price",
      "@type": "rdf:Property",
      "rdfs:label": "Ask Price",
      "rdfs:comment": "The current best ask price, `null` if there aren't any asks",
      "rdfs:domain": {
        "@id": "deribit:book_summary"
      }
    },
    {
      "@id": "deribit:book_summary_mid_price",
      "@type": "rdf:Property",
      "rdfs:label": "Mid Price",
      "rdfs:comment": "The average of the best bid and ask, `null` if there aren't any asks or bids",
      "rdfs:domain": {
        "@id": "deribit:book_summary"
      }
    },
    {
      "@id": "deribit:book_summary_mark_price",
      "@type": "rdf:Property",
      "rdfs:label": "Mark Price",
      "rdfs:comment": "The current instrument market price",
      "rdfs:domain": {
        "@id": "deribit:book_summary"
      }
    },
    {
      "@id": "deribit:book_summary_last",
      "@type": "rdf:Property",
      "rdfs:label": "Last",
      "rdfs:comment": "The price of the latest trade, `null` if there weren't any trades",
      "rdfs:domain": {
        "@id": "deribit:book_summary"
      }
    },
    {
      "@id": "deribit:book_summary_open_interest",
      "@type": "rdf:Property",
      "rdfs:label": "Open Interest",
      "rdfs:comment": "Optional (only for derivatives). The total amount of outstanding contracts in the corresponding amount units. For perpetual and inverse futures the amount is in USD units. For options and linear futures it is the underlying base currency coin.",
      "rdfs:domain": {
        "@id": "deribit:book_summary"
      }
    },
    {
      "@id": "deribit:book_summary_creation_timestamp",
      "@type": "rdf:Property",
      "rdfs:label": "Creation Timestamp",
      "rdfs:comment": "creation_timestamp property of book_summary",
      "rdfs:domain": {
        "@id": "deribit:book_summary"
      }
    },
    {
      "@id": "deribit:book_summary_estimated_delivery_price",
      "@type": "rdf:Property",
      "rdfs:label": "Estimated Delivery Price",
      "rdfs:comment": "Optional (only for derivatives). Estimated delivery price for the market.",
      "rdfs:domain": {
        "@id": "deribit:book_summary"
      }
    },
    {
      "@id": "deribit:book_summary_volume_usd",
      "@type": "rdf:Property",
      "rdfs:label": "Volume Usd",
      "rdfs:comment": "Volume in USD",
      "rdfs:domain": {
        "@id": "deribit:book_summary"
      }
    },
    {
      "@id": "deribit:book_summary_volume_notional",
      "@type": "rdf:Property",
      "rdfs:label": "Volume Notional",
      "rdfs:comment": "Volume in quote currency (futures and spots only)",
      "rdfs:domain": {
        "@id": "deribit:book_summary"
      }
    },
    {
      "@id": "deribit:book_summary_current_funding",
      "@type": "rdf:Property",
      "rdfs:label": "Current Funding",
      "rdfs:comment": "Current funding (perpetual only)",
      "rdfs:domain": {
        "@id": "deribit:book_summary"
      }
    },
    {
      "@id": "deribit:book_summary_funding_8h",
      "@type": "rdf:Property",
      "rdfs:label": "Funding 8H",
      "rdfs:comment": "Funding 8h (perpetual only)",
      "rdfs:domain": {
        "@id": "deribit:book_summary"
      }
    },
    {
      "@id": "deribit:book_summary_mark_iv",
      "@type": "rdf:Property",
      "rdfs:label": "Mark Iv",
      "rdfs:comment": "mark_iv property of book_summary",
      "rdfs:domain": {
        "@id": "deribit:book_summary"
      }
    },
    {
      "@id": "deribit:book_summary_interest_rate",
      "@type": "rdf:Property",
      "rdfs:label": "Interest Rate",
      "rdfs:comment": "Interest rate used in implied volatility calculations (options only)",
      "rdfs:domain": {
        "@id": "deribit:book_summary"
      }
    },
    {
      "@id": "deribit:book_summary_underlying_index",
      "@type": "rdf:Property",
      "rdfs:label": "Underlying Index",
      "rdfs:comment": "Name of the underlying future, or `'index_price'` (options only)",
      "rdfs:domain": {
        "@id": "deribit:book_summary"
      }
    },
    {
      "@id": "deribit:book_summary_underlying_price",
      "@type": "rdf:Property",
      "rdfs:label": "Underlying Price",
      "rdfs:comment": "underlying price for implied volatility calculations (options only)",
      "rdfs:domain": {
        "@id": "deribit:book_summary"
      }
    },
    {
      "@id": "deribit:book_summary_price_change",
      "@type": "rdf:Property",
      "rdfs:label": "Price Change",
      "rdfs:comment": "24-hour price change expressed as a percentage, `null` if there weren't any trades",
      "rdfs:domain": {
        "@id": "deribit:book_summary"
      }
    },
    {
      "@id": "deribit:position",
      "@type": "rdfs:Class",
      "rdfs:label": "Position",
      "rdfs:comment": "Deribit position object"
    },
    {
      "@id": "deribit:position_instrument_name",
      "@type": "rdf:Property",
      "rdfs:label": "Instrument Name",
      "rdfs:comment": "instrument_name property of position",
      "rdfs:domain": {
        "@id": "deribit:position"
      }
    },
    {
      "@id": "deribit:position_kind",
      "@type": "rdf:Property",
      "rdfs:label": "Kind",
      "rdfs:comment": "kind property of position",
      "rdfs:domain": {
        "@id": "deribit:position"
      }
    },
    {
      "@id": "deribit:position_average_price",
      "@type": "rdf:Property",
      "rdfs:label": "Average Price",
      "rdfs:comment": "Average price of trades that built this position",
      "rdfs:domain": {
        "@id": "deribit:position"
      }
    },
    {
      "@id": "deribit:position_direction",
      "@type": "rdf:Property",
      "rdfs:label": "Direction",
      "rdfs:comment": "direction property of position",
      "rdfs:domain": {
        "@id": "deribit:position"
      }
    },
    {
      "@id": "deribit:position_mark_price",
      "@type": "rdf:Property",
      "rdfs:label": "Mark Price",
      "rdfs:comment": "Current mark price for position's instrument",
      "rdfs:domain": {
        "@id": "deribit:position"
      }
    },
    {
      "@id": "deribit:position_delta",
      "@type": "rdf:Property",
      "rdfs:label": "Delta",
      "rdfs:comment": "Delta parameter",
      "rdfs:domain": {
        "@id": "deribit:position"
      }
    },
    {
      "@id": "deribit:position_gamma",
      "@type": "rdf:Property",
      "rdfs:label": "Gamma",
      "rdfs:comment": "Only for options, Gamma parameter",
      "rdfs:domain": {
        "@id": "deribit:position"
      }
    },
    {
      "@id": "deribit:position_vega",
      "@type": "rdf:Property",
      "rdfs:label": "Vega",
      "rdfs:comment": "Only for options, Vega parameter",
      "rdfs:domain": {
        "@id": "deribit:position"
      }
    },
    {
      "@id": "deribit:position_theta",
      "@type": "rdf:Property",
      "rdfs:label": "Theta",
      "rdfs:comment": "Only for options, Theta parameter",
      "rdfs:domain": {
        "@id": "deribit:position"
      }
    },
    {
      "@id": "deribit:position_index_price",
      "@type": "rdf:Property",
      "rdfs:label": "Index Price",
      "rdfs:comment": "Current index price",
      "rdfs:domain": {
        "@id": "deribit:position"
      }
    },
    {
      "@id": "deribit:position_initial_margin",
      "@type": "rdf:Property",
      "rdfs:label": "Initial Margin",
      "rdfs:comment": "Initial margin",
      "rdfs:domain": {
        "@id": "deribit:position"
      }
    },
    {
      "@id": "deribit:position_maintenance_margin",
      "@type": "rdf:Property",
      "rdfs:label": "Maintenance Margin",
      "rdfs:comment": "Maintenance margin",
      "rdfs:domain": {
        "@id": "deribit:position"
      }
    },
    {
      "@id": "deribit:position_settlement_price",
      "@type": "rdf:Property",
      "rdfs:label": "Settlement Price",
      "rdfs:comment": "Optional (not added for spot). Last settlement price for position's instrument 0 if instrument wasn't settled yet",
      "rdfs:domain": {
        "@id": "deribit:position"
      }
    },
    {
      "@id": "deribit:position_total_profit_loss",
      "@type": "rdf:Property",
      "rdfs:label": "Total Profit Loss",
      "rdfs:comment": "Profit or loss from position",
      "rdfs:domain": {
        "@id": "deribit:position"
      }
    },
    {
      "@id": "deribit:position_floating_profit_loss",
      "@type": "rdf:Property",
      "rdfs:label": "Floating Profit Loss",
      "rdfs:comment": "Floating profit or loss",
      "rdfs:domain": {
        "@id": "deribit:position"
      }
    },
    {
      "@id": "deribit:position_realized_profit_loss",
      "@type": "rdf:Property",
      "rdfs:label": "Realized Profit Loss",
      "rdfs:comment": "Realized profit or loss",
      "rdfs:domain": {
        "@id": "deribit:position"
      }
    },
    {
      "@id": "deribit:position_size",
      "@type": "rdf:Property",
      "rdfs:label": "Size",
      "rdfs:comment": "Position size for futures size in quote currency (e.g. USD), for options size is in base currency (e.g. BTC)",
      "rdfs:domain": {
        "@id": "deribit:position"
      }
    },
    {
      "@id": "deribit:position_size_currency",
      "@type": "rdf:Property",
      "rdfs:label": "Size Currency",
      "rdfs:comment": "Only for futures, position size in base currency",
      "rdfs:domain": {
        "@id": "deribit:position"
      }
    },
    {
      "@id": "deribit:position_average_price_usd",
      "@type": "rdf:Property",
      "rdfs:label": "Average Price Usd",
      "rdfs:comment": "Only for options, average price in USD",
      "rdfs:domain": {
        "@id": "deribit:position"
      }
    },
    {
      "@id": "deribit:position_floating_profit_loss_usd",
      "@type": "rdf:Property",
      "rdfs:label": "Floating Profit Loss Usd",
      "rdfs:comment": "Only for options, floating profit or loss in USD",
      "rdfs:domain": {
        "@id": "deribit:position"
      }
    },
    {
      "@id": "deribit:position_leverage",
      "@type": "rdf:Property",
      "rdfs:label": "Leverage",
      "rdfs:comment": "Current available leverage for future position",
      "rdfs:domain": {
        "@id": "deribit:position"
      }
    },
    {
      "@id": "deribit:position_realized_funding",
      "@type": "rdf:Property",
      "rdfs:label": "Realized Funding",
      "rdfs:comment": "Realized Funding in current session included in session realized profit or loss, only for positions of perpetual instruments",
      "rdfs:domain": {
        "@id": "deribit:position"
      }
    },
    {
      "@id": "deribit:position_interest_value",
      "@type": "rdf:Property",
      "rdfs:label": "Interest Value",
      "rdfs:comment": "Value used to calculate `realized_funding` (perpetual only)",
      "rdfs:domain": {
        "@id": "deribit:position"
      }
    },
    {
      "@id": "deribit:position_with_elp",
      "@type": "rdfs:Class",
      "rdfs:label": "Position With Elp",
      "rdfs:comment": "Deribit position_with_elp object"
    },
    {
      "@id": "deribit:transfer_item",
      "@type": "rdfs:Class",
      "rdfs:label": "Transfer Item",
      "rdfs:comment": "Deribit transfer_item object"
    },
    {
      "@id": "deribit:transfer_item_id",
      "@type": "rdf:Property",
      "rdfs:label": "Id",
      "rdfs:comment": "id property of transfer_item",
      "rdfs:domain": {
        "@id": "deribit:transfer_item"
      }
    },
    {
      "@id": "deribit:transfer_item_created_timestamp",
      "@type": "rdf:Property",
      "rdfs:label": "Created Timestamp",
      "rdfs:comment": "created_timestamp property of transfer_item",
      "rdfs:domain": {
        "@id": "deribit:transfer_item"
      }
    },
    {
      "@id": "deribit:transfer_item_type",
      "@type": "rdf:Property",
      "rdfs:label": "Type",
      "rdfs:comment": "type property of transfer_item",
      "rdfs:domain": {
        "@id": "deribit:transfer_item"
      }
    },
    {
      "@id": "deribit:transfer_item_currency",
      "@type": "rdf:Property",
      "rdfs:label": "Currency",
      "rdfs:comment": "currency property of transfer_item",
      "rdfs:domain": {
        "@id": "deribit:transfer_item"
      }
    },
    {
      "@id": "deribit:transfer_item_amount",
      "@type": "rdf:Property",
      "rdfs:label": "Amount",
      "rdfs:comment": "amount property of transfer_item",
      "rdfs:domain": {
        "@id": "deribit:transfer_item"
      }
    },
    {
      "@id": "deribit:transfer_item_other_side",
      "@type": "rdf:Property",
      "rdfs:label": "Other Side",
      "rdfs:comment": "other_side property of transfer_item",
      "rdfs:domain": {
        "@id": "deribit:transfer_item"
      }
    },
    {
      "@id": "deribit:transfer_item_state",
      "@type": "rdf:Property",
      "rdfs:label": "State",
      "rdfs:comment": "state property of transfer_item",
      "rdfs:domain": {
        "@id": "deribit:transfer_item"
      }
    },
    {
      "@id": "deribit:transfer_item_direction",
      "@type": "rdf:Property",
      "rdfs:label": "Direction",
      "rdfs:comment": "direction property of transfer_item",
      "rdfs:domain": {
        "@id": "deribit:transfer_item"
      }
    },
    {
      "@id": "deribit:transfer_item_updated_timestamp",
      "@type": "rdf:Property",
      "rdfs:label": "Updated Timestamp",
      "rdfs:comment": "updated_timestamp property of transfer_item",
      "rdfs:domain": {
        "@id": "deribit:transfer_item"
      }
    },
    {
      "@id": "deribit:transfer_item_nonce",
      "@type": "rdf:Property",
      "rdfs:label": "Nonce",
      "rdfs:comment": "Optional idempotency nonce if provided in the request",
