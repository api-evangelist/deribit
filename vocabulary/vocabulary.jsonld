    },
    {
      "@id": "deribit:interest_rate",
      "@type": "rdfs:Class",
      "rdfs:label": "Interest Rate",
      "rdfs:comment": "Interest rate used in implied volatility calculations (options only)"
    },
    {
      "@id": "deribit:bid_iv",
      "@type": "rdfs:Class",
      "rdfs:label": "Bid Iv",
      "rdfs:comment": "(Only for option) implied volatility for best bid"
    },
    {
      "@id": "deribit:ask_iv",
      "@type": "rdfs:Class",
      "rdfs:label": "Ask Iv",
      "rdfs:comment": "(Only for option) implied volatility for best ask"
    },
    {
      "@id": "deribit:mark_iv",
      "@type": "rdfs:Class",
      "rdfs:label": "Mark Iv",
      "rdfs:comment": "(Only for option) implied volatility for mark price"
    },
    {
      "@id": "deribit:funding_8h",
      "@type": "rdfs:Class",
      "rdfs:label": "Funding 8H",
      "rdfs:comment": "Funding 8h (perpetual only)"
    },
    {
      "@id": "deribit:interest_value",
      "@type": "rdfs:Class",
      "rdfs:label": "Interest Value",
      "rdfs:comment": "Value used to calculate `realized_funding` in positions (perpetual only)"
    },
    {
      "@id": "deribit:current_funding",
      "@type": "rdfs:Class",
      "rdfs:label": "Current Funding",
      "rdfs:comment": "Current funding (perpetual only)"
    },
    {
      "@id": "deribit:delivery_price",
      "@type": "rdfs:Class",
      "rdfs:label": "Delivery Price",
      "rdfs:comment": "The settlement price for the instrument. Only when `state = closed`"
    },
    {
      "@id": "deribit:settlement_price",
      "@type": "rdfs:Class",
      "rdfs:label": "Settlement Price",
      "rdfs:comment": "Optional (not added for spot). The settlement price for the instrument. Only when `state = open`"
    },
    {
      "@id": "deribit:volume_usd",
      "@type": "rdfs:Class",
      "rdfs:label": "Volume Usd",
      "rdfs:comment": "Volume in usd (futures only)"
    },
    {
      "@id": "deribit:estimated_delivery_price",
      "@type": "rdfs:Class",
      "rdfs:label": "Estimated Delivery Price",
      "rdfs:comment": "Estimated delivery price for the market. For more details, see Contract Specification > General Documentation > Expiration Price"
    },
    {
      "@id": "deribit:open_interest",
      "@type": "rdfs:Class",
      "rdfs:label": "Open Interest",
      "rdfs:comment": "The total amount of outstanding contracts in the corresponding amount units. For perpetual and inverse futures the amount is in USD units. For options and linear futures it is the underlying base currency coin."
    },
    {
      "@id": "deribit:index_price",
      "@type": "rdfs:Class",
      "rdfs:label": "Index Price",
      "rdfs:comment": "Current index price"
    },
    {
      "@id": "deribit:index_name",
      "@type": "rdfs:Class",
      "rdfs:label": "Index Name",
      "rdfs:comment": "Index identifier, matches (base) cryptocurrency with quote currency"
    },
    {
      "@id": "deribit:index_name_for_dvol",
      "@type": "rdfs:Class",
      "rdfs:label": "Index Name For Dvol",
      "rdfs:comment": "Index identifier supported for DVOL"
    },
    {
      "@id": "deribit:index_name_derivative",
      "@type": "rdfs:Class",
      "rdfs:label": "Index Name Derivative",
      "rdfs:comment": "Index identifier of derivative instrument on the platform"
    },
    {
      "@id": "deribit:volatility",
      "@type": "rdfs:Class",
      "rdfs:label": "Volatility",
      "rdfs:comment": "Value of the corresponding volatility"
    },
    {
      "@id": "deribit:implied_volatility",
      "@type": "rdfs:Class",
      "rdfs:label": "Implied Volatility",
      "rdfs:comment": "Value of the volatility of the underlying instrument"
    },
    {
      "@id": "deribit:chart_volume",
      "@type": "rdfs:Class",
      "rdfs:label": "Chart Volume",
      "rdfs:comment": "// todo"
    },
    {
      "@id": "deribit:key_id",
      "@type": "rdfs:Class",
      "rdfs:label": "Key Id",
      "rdfs:comment": "Key identifier"
    },
    {
      "@id": "deribit:security_key_id",
      "@type": "rdfs:Class",
      "rdfs:label": "Security Key Id",
      "rdfs:comment": "Security Key Identifier"
    },
    {
      "@id": "deribit:security_key_name",
      "@type": "rdfs:Class",
      "rdfs:label": "Security Key Name",
      "rdfs:comment": "Security Key name"
    },
    {
      "@id": "deribit:security_key_type",
      "@type": "rdfs:Class",
      "rdfs:label": "Security Key Type",
      "rdfs:comment": "Security Key type"
    },
    {
      "@id": "deribit:security_key_assignments",
      "@type": "rdfs:Class",
      "rdfs:label": "Security Key Assignments",
      "rdfs:comment": "Deribit security_key_assignments object"
    },
    {
      "@id": "deribit:security_key_timestamp",
      "@type": "rdfs:Class",
      "rdfs:label": "Security Key Timestamp",
      "rdfs:comment": "Timestamp when Security Key was created (milliseconds since the UNIX epoch)"
    },
    {
      "@id": "deribit:security_key_last_used",
      "@type": "rdfs:Class",
      "rdfs:label": "Security Key Last Used",
      "rdfs:comment": "Timestamp when Security Key was last used (milliseconds since the UNIX epoch)"
    },
    {
      "@id": "deribit:client_id",
      "@type": "rdfs:Class",
      "rdfs:label": "Client Id",
      "rdfs:comment": "Client identifier used for authentication"
    },
    {
      "@id": "deribit:public_key",
      "@type": "rdfs:Class",
      "rdfs:label": "Public Key",
      "rdfs:comment": "PEM encoded public key (Ed25519/RSA) used for asymmetric signatures (optional)"
    },
    {
      "@id": "deribit:client_secret",
      "@type": "rdfs:Class",
      "rdfs:label": "Client Secret",
      "rdfs:comment": "Client secret or MD5 fingerprint of public key used for authentication"
    },
    {
      "@id": "deribit:api_key_default",
      "@type": "rdfs:Class",
      "rdfs:label": "Api Key Default",
      "rdfs:comment": "Informs whether this api key is default (field is deprecated and will be removed in the future)"
    },
    {
      "@id": "deribit:api_key_name",
      "@type": "rdfs:Class",
      "rdfs:label": "Api Key Name",
      "rdfs:comment": "Api key name that can be displayed in transaction log"
    },
    {
      "@id": "deribit:api_key_features",
      "@type": "rdfs:Class",
      "rdfs:label": "Api Key Features",
      "rdfs:comment": "List of enabled advanced on-key features.<br><br><b>Available options:</b><br>- <code>restricted_block_trades</code>: Limit the block_trade read the scope of the API key to block trades that have been made using this specific API key<br>- <code>block_trade_approval</code>: Block trades created using this API key require additional user approval. Methods that use <code>block_rfq</code> scope are not affected by Block Trade approval feature"
    },
    {
      "@id": "deribit:max_scope",
      "@type": "rdfs:Class",
      "rdfs:label": "Max Scope",
      "rdfs:comment": "Describes maximal access for tokens generated with given key. If scope is not provided, its value is set as none.\n\n**\ud83d\udcd6 Related Article:** [Access Scope](https://docs.deribit.com/articles/access-scope)\n"
    },
    {
      "@id": "deribit:api_key_enabled",
      "@type": "rdfs:Class",
      "rdfs:label": "Api Key Enabled",
      "rdfs:comment": "Informs whether api key is enabled and can be used for authentication"
    },
    {
      "@id": "deribit:enabled_field",
      "@type": "rdfs:Class",
      "rdfs:label": "Enabled Field",
      "rdfs:comment": "Current configuration status"
    },
    {
      "@id": "deribit:cod_scope",
      "@type": "rdfs:Class",
      "rdfs:label": "Cod Scope",
      "rdfs:comment": "Informs if Cancel on Disconnect was checked for the current connection or the account"
    },
    {
      "@id": "deribit:nonce",
      "@type": "rdfs:Class",
      "rdfs:label": "Nonce",
      "rdfs:comment": "Nonce"
    },
    {
      "@id": "deribit:role",
      "@type": "rdfs:Class",
      "rdfs:label": "Role",
      "rdfs:comment": "Trade role of the user: `maker` or `taker`"
    },
    {
      "@id": "deribit:fee_role",
      "@type": "rdfs:Class",
      "rdfs:label": "Fee Role",
      "rdfs:comment": "Fee role of the user: `maker` or `taker`. Can be different from trade role of the user when iceberg order was involved in matching."
    },
    {
      "@id": "deribit:user_id",
      "@type": "rdfs:Class",
      "rdfs:label": "User Id",
      "rdfs:comment": "Unique user identifier"
    },
    {
      "@id": "deribit:username",
      "@type": "rdfs:Class",
      "rdfs:label": "Username",
      "rdfs:comment": "System name or user defined subaccount alias"
    },
    {
      "@id": "deribit:custody_name",
      "@type": "rdfs:Class",
      "rdfs:label": "Custody Name",
      "rdfs:comment": "Custody name"
    },
    {
      "@id": "deribit:delta_total",
      "@type": "rdfs:Class",
      "rdfs:label": "Delta Total",
      "rdfs:comment": "The sum of position deltas. \n\n**DeltaTotal = Net Transaction Delta of options + BTC Position of Futures**\n\nThe DeltaTotal uses the Net Transaction Delta (or price adjusted Delta) of the options, where Net Transaction Delta = Black Scholes Delta - Mark Price of Options.\n\nThis is because, from a risk perspective, we are interested in the change in Bitcoin price as the underlying changes.\n\nYou should actually treat your delta as **Equity + Delta Total** if you want to have less risk for your USD PnL.\n\n\u26a0\ufe0f **During the 30 minute settlement period we decay your Delta.** See [Delta decay during settlement](https://support.deribit.com/hc/en-us/articles/25944751433757-Delta-decay-during-settlement) for more details.\n"
    },
    {
      "@id": "deribit:projected_delta_total",
      "@type": "rdfs:Class",
      "rdfs:label": "Projected Delta Total",
      "rdfs:comment": "The sum of position deltas without positions that will expire during closest expiration"
    },
    {
      "@id": "deribit:projected_maintenance_margin",
      "@type": "rdfs:Class",
      "rdfs:label": "Projected Maintenance Margin",
      "rdfs:comment": "Projected maintenance margin. When cross collateral is enabled, this aggregated value is calculated by converting the sum of each cross collateral currency's value to the given currency, using each cross collateral currency's index."
    },
    {
      "@id": "deribit:estimated_liquidation_ratio",
      "@type": "rdfs:Class",
      "rdfs:label": "Estimated Liquidation Ratio",
      "rdfs:comment": "Estimated Liquidation Ratio is returned only for users without portfolio margining enabled. Multiplying it by future position's market price returns its estimated liquidation price. When cross collateral is enabled, this aggregated value is calculated by converting the sum of each cross collateral currency's value to the given currency, using each cross collateral currency's index."
    },
    {
      "@id": "deribit:projected_initial_margin",
      "@type": "rdfs:Class",
      "rdfs:label": "Projected Initial Margin",
      "rdfs:comment": "Projected initial margin. When cross collateral is enabled, this aggregated value is calculated by converting the sum of each cross collateral currency's value to the given currency, using each cross collateral currency's index."
    },
    {
      "@id": "deribit:additional_reserve",
      "@type": "rdfs:Class",
      "rdfs:label": "Additional Reserve",
      "rdfs:comment": "The account's balance reserved in other orders"
    },
    {
      "@id": "deribit:rate_and_burst",
      "@type": "rdfs:Class",
      "rdfs:label": "Rate And Burst",
      "rdfs:comment": "Deribit rate_and_burst object"
    },
    {
      "@id": "deribit:rate_and_burst_rate",
      "@type": "rdf:Property",
      "rdfs:label": "Rate",
      "rdfs:comment": "Number of requests per second allowed for user",
