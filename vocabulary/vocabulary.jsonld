      "rdfs:comment": "Option price in USD (Only if `advanced=\"usd\"`)"
    },
    {
      "@id": "deribit:triggered",
      "@type": "rdfs:Class",
      "rdfs:label": "Triggered",
      "rdfs:comment": "Whether the trigger order has been triggered"
    },
    {
      "@id": "deribit:trigger",
      "@type": "rdfs:Class",
      "rdfs:label": "Trigger",
      "rdfs:comment": "Trigger type (only for trigger orders). Allowed values: `\"index_price\"`, `\"mark_price\"`, `\"last_price\"`."
    },
    {
      "@id": "deribit:trigger_price",
      "@type": "rdfs:Class",
      "rdfs:label": "Trigger Price",
      "rdfs:comment": "Trigger price (Only for future trigger orders)"
    },
    {
      "@id": "deribit:trigger_offset",
      "@type": "rdfs:Class",
      "rdfs:label": "Trigger Offset",
      "rdfs:comment": "The maximum deviation from the price peak beyond which the order will be triggered (Only for trailing trigger orders)"
    },
    {
      "@id": "deribit:trigger_reference_price",
      "@type": "rdfs:Class",
      "rdfs:label": "Trigger Reference Price",
      "rdfs:comment": "The price of the given trigger at the time when the order was placed (Only for trailing trigger orders)"
    },
    {
      "@id": "deribit:sorting",
      "@type": "rdfs:Class",
      "rdfs:label": "Sorting",
      "rdfs:comment": "Deribit sorting object"
    },
    {
      "@id": "deribit:contract_size",
      "@type": "rdfs:Class",
      "rdfs:label": "Contract Size",
      "rdfs:comment": "Contract size, for futures in USD, for options in base currency of the instrument (BTC, ETH, ...)"
    },
    {
      "@id": "deribit:currency_address",
      "@type": "rdfs:Class",
      "rdfs:label": "Currency Address",
      "rdfs:comment": "Address in proper format for currency"
    },
    {
      "@id": "deribit:currency_address_type",
      "@type": "rdfs:Class",
      "rdfs:label": "Currency Address Type",
      "rdfs:comment": "Address type acording to Notabene"
    },
    {
      "@id": "deribit:address_book_type",
      "@type": "rdfs:Class",
      "rdfs:label": "Address Book Type",
      "rdfs:comment": "Address book type"
    },
    {
      "@id": "deribit:address_book_type_without_deposit_source",
      "@type": "rdfs:Class",
      "rdfs:label": "Address Book Type Without Deposit Source",
      "rdfs:comment": "Address book type"
    },
    {
      "@id": "deribit:address_label",
      "@type": "rdfs:Class",
      "rdfs:label": "Address Label",
      "rdfs:comment": "Label of the address book entry"
    },
    {
      "@id": "deribit:beneficiary_vasp_name",
      "@type": "rdfs:Class",
      "rdfs:label": "Beneficiary Vasp Name",
      "rdfs:comment": "Name of beneficiary VASP"
    },
    {
      "@id": "deribit:beneficiary_vasp_did",
      "@type": "rdfs:Class",
      "rdfs:label": "Beneficiary Vasp Did",
      "rdfs:comment": "DID of beneficiary VASP"
    },
    {
      "@id": "deribit:beneficiary_first_name",
      "@type": "rdfs:Class",
      "rdfs:label": "Beneficiary First Name",
      "rdfs:comment": "First name of the beneficiary (if beneficiary is a person)"
    },
    {
      "@id": "deribit:beneficiary_last_name",
      "@type": "rdfs:Class",
      "rdfs:label": "Beneficiary Last Name",
      "rdfs:comment": "Last name of the beneficiary (if beneficiary is a person)"
    },
    {
      "@id": "deribit:beneficiary_company_name",
      "@type": "rdfs:Class",
      "rdfs:label": "Beneficiary Company Name",
      "rdfs:comment": "Company name of the beneficiary (if beneficiary is a company)"
    },
    {
      "@id": "deribit:beneficiary_address",
      "@type": "rdfs:Class",
      "rdfs:label": "Beneficiary Address",
      "rdfs:comment": "Geographical address of the beneficiary"
    },
    {
      "@id": "deribit:beneficiary_vasp_website",
      "@type": "rdfs:Class",
      "rdfs:label": "Beneficiary Vasp Website",
      "rdfs:comment": "Website of the beneficiary VASP"
    },
    {
      "@id": "deribit:agree_to_share_with_3rd_party",
      "@type": "rdfs:Class",
      "rdfs:label": "Agree To Share With 3Rd Party",
      "rdfs:comment": "Indicates that the user agreed to shared provided information with 3rd parties"
    },
    {
      "@id": "deribit:personal_wallet",
      "@type": "rdfs:Class",
      "rdfs:label": "Personal Wallet",
      "rdfs:comment": "The user confirms that he provided address belongs to him and he has access to it via an un-hosted wallet software"
    },
    {
      "@id": "deribit:extra_currencies",
      "@type": "rdfs:Class",
      "rdfs:label": "Extra Currencies",
      "rdfs:comment": "The user can pass a list of currencies to add the address for. It is currently available ONLY for ERC20 currencies. Without passing this paramater for an ERC20 currency, the address will be added to ALL of the ERC20 currencies."
    },
    {
      "@id": "deribit:address_info_required",
      "@type": "rdfs:Class",
      "rdfs:label": "Address Info Required",
      "rdfs:comment": "Signalises that addition information regarding the beneficiary of the address is required"
    },
    {
      "@id": "deribit:status",
      "@type": "rdfs:Class",
      "rdfs:label": "Status",
      "rdfs:comment": "Wallet address status, values: [`admin_locked`, `waiting`, `confirmed`, `ready`]"
    },
    {
      "@id": "deribit:waiting_timestamp",
      "@type": "rdfs:Class",
      "rdfs:label": "Waiting Timestamp",
      "rdfs:comment": "Timestamp when the address will be ready"
    },
    {
      "@id": "deribit:requires_confirmation",
      "@type": "rdfs:Class",
      "rdfs:label": "Requires Confirmation",
      "rdfs:comment": "If address requires email confirmation for withdrawals"
    },
    {
      "@id": "deribit:requires_confirmation_change",
      "@type": "rdfs:Class",
      "rdfs:label": "Requires Confirmation Change",
      "rdfs:comment": "If email confirmation change is in progress"
    },
    {
      "@id": "deribit:deposit_state",
      "@type": "rdfs:Class",
      "rdfs:label": "Deposit State",
      "rdfs:comment": "Deposit state. Allowed values: <li><code>pending</code>: deposit detected on blockchain/system, compliance not yet finished</li> <li><code>completed</code>: compliance check finished successfully</li> <li><code>rejected</code>: deposit failed compliance and must be handled manually</li> <li><code>replaced</code>: deposit transaction was replaced on the blockchain and should have a new transaction hash</li>"
    },
    {
      "@id": "deribit:withdrawal_state",
      "@type": "rdfs:Class",
      "rdfs:label": "Withdrawal State",
      "rdfs:comment": "Withdrawal state, allowed values : `unconfirmed`, `confirmed`, `cancelled`, `completed`, `interrupted`, `rejected`"
    },
    {
      "@id": "deribit:clearance_state",
      "@type": "rdfs:Class",
      "rdfs:label": "Clearance State",
      "rdfs:comment": "Clearance state indicating the current status of the transaction clearance process. Allowed values: <li><code>in_progress</code>: clearance process is in progress</li> <li><code>pending_admin_decision</code>: transaction is under manual review by Deribit admin</li> <li><code>pending_user_input</code>: user should provide additional information regarding the transaction</li> <li><code>success</code>: clearance process completed successfully</li> <li><code>failed</code>: clearance process failed, transaction is rejected</li> <li><code>cancelled</code>: transaction is cancelled (currently used only for withdrawals, meaning the withdrawal is cancelled)</li> <li><code>refund_initiated</code>: clearance process failed, transaction refund is initiated, funds are removed from Deribit balance (valid for deposits only)</li> <li><code>refunded</code>: clearance process failed, deposit amount is refunded back to the client (valid for deposits only)</li>"
    },
    {
      "@id": "deribit:fee",
      "@type": "rdfs:Class",
      "rdfs:label": "Fee",
      "rdfs:comment": "Fee in currency"
    },
    {
      "@id": "deribit:currency_transaction_id",
      "@type": "rdfs:Class",
      "rdfs:label": "Currency Transaction Id",
      "rdfs:comment": "Transaction id in proper format for currency, `null` if id is not available"
    },
    {
      "@id": "deribit:result_count",
      "@type": "rdfs:Class",
      "rdfs:label": "Result Count",
      "rdfs:comment": "Total number of results available"
    },
    {
      "@id": "deribit:transfer_id",
      "@type": "rdfs:Class",
      "rdfs:label": "Transfer Id",
      "rdfs:comment": "Id of transfer"
    },
    {
      "@id": "deribit:transfer_type",
      "@type": "rdfs:Class",
      "rdfs:label": "Transfer Type",
      "rdfs:comment": "Type of transfer: `user` - sent to user, `subaccount` - sent to subaccount"
    },
    {
      "@id": "deribit:transfer_direction",
      "@type": "rdfs:Class",
      "rdfs:label": "Transfer Direction",
      "rdfs:comment": "Transfer direction"
    },
    {
      "@id": "deribit:transfer_state",
      "@type": "rdfs:Class",
      "rdfs:label": "Transfer State",
      "rdfs:comment": "Transfer state, allowed values : `prepared`, `confirmed`, `cancelled`, `waiting_for_admin`, `insufficient_funds`,  `withdrawal_limit` otherwise rejection reason"
    },
    {
      "@id": "deribit:transfer_other_side",
      "@type": "rdfs:Class",
      "rdfs:label": "Transfer Other Side",
      "rdfs:comment": "For transfer from/to subaccount returns this subaccount name, for transfer to other account returns address, for transfer from other account returns that accounts username."
    },
    {
      "@id": "deribit:trade_seq",
      "@type": "rdfs:Class",
      "rdfs:label": "Trade Seq",
      "rdfs:comment": "The sequence number of the trade within instrument"
    },
    {
      "@id": "deribit:wallet_address_type",
      "@type": "rdfs:Class",
      "rdfs:label": "Wallet Address Type",
      "rdfs:comment": "Address type/purpose, allowed values : `deposit`"
    },
    {
      "@id": "deribit:best_bid_price",
      "@type": "rdfs:Class",
      "rdfs:label": "Best Bid Price",
      "rdfs:comment": "The current best bid price, `null` if there aren't any bids"
    },
    {
      "@id": "deribit:best_bid_amount",
      "@type": "rdfs:Class",
      "rdfs:label": "Best Bid Amount",
      "rdfs:comment": "It represents the requested order size of all best bids"
    },
    {
      "@id": "deribit:best_ask_price",
      "@type": "rdfs:Class",
      "rdfs:label": "Best Ask Price",
      "rdfs:comment": "The current best ask price, `null` if there aren't any asks"
    },
    {
      "@id": "deribit:best_ask_amount",
      "@type": "rdfs:Class",
      "rdfs:label": "Best Ask Amount",
      "rdfs:comment": "It represents the requested order size of all best asks"
    },
    {
      "@id": "deribit:min_price",
