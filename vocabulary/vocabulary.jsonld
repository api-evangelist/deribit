      "rdfs:comment": "The mark price for the instrument"
    },
    {
      "@id": "deribit:last_price",
      "@type": "rdfs:Class",
      "rdfs:label": "Last Price",
      "rdfs:comment": "The price for the last trade"
    },
    {
      "@id": "deribit:underlying_price",
      "@type": "rdfs:Class",
      "rdfs:label": "Underlying Price",
      "rdfs:comment": "Underlying price for implied volatility calculations (options only)"
