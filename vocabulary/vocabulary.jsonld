        "@id": "deribit:pending_block_trade"
      }
    },
    {
      "@id": "deribit:pending_block_trade_state",
      "@type": "rdf:Property",
      "rdfs:label": "State",
      "rdfs:comment": "State of the pending block trade for current user.",
