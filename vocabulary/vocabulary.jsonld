        "@id": "deribit:rate_and_burst"
      }
    },
    {
      "@id": "deribit:rate_and_burst_burst",
      "@type": "rdf:Property",
      "rdfs:label": "Burst",
      "rdfs:comment": "Maximal number of requests allowed for user in burst mode",
      "rdfs:domain": {
        "@id": "deribit:rate_and_burst"
      }
    },
    {
      "@id": "deribit:group_rate_and_burst",
