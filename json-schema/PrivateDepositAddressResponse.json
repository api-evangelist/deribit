          "$ref": "#/components/schemas/timestamp"
        },
        "currency": {
          "$ref": "#/components/schemas/currency"
        },
        "address": {
          "$ref": "#/components/schemas/currency_address"
        },
        "type": {
          "$ref": "#/components/schemas/wallet_address_type"
        }
      },
      "required": [
        "creation_timestamp",
        "currency",
        "address",
        "type"
      ],
      "description": "Object if address is created, null otherwise"
