{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api-evangelist.github.io/deribit/json-schema/position_with_elp.json",
  "title": "Position With Elp",
  "allOf": [
    {
      "$ref": "#/components/schemas/position"
    },
    {
      "properties": {
        "estimated_liquidation_price": {
          "type": "number",
          "description": "Estimated liquidation price, added only for futures, for users with `segregated_sm` margin model"
        },
        "open_orders_margin": {
          "type": "number",
          "description": "Open orders margin"
        }
      },
      "required": [
        "estimated_liquidation_price",
        "open_orders_margin"
      ]
    }
  ]
}