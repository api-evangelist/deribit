{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api-evangelist.github.io/deribit/json-schema/PrivateGetLegPricesResponse.json",
  "title": "Privategetlegpricesresponse",
  "properties": {
    "jsonrpc": {
      "type": "string",
